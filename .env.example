# Copy this file to .env for local development.
# In Azure App Service, set these as Application Settings (Configuration > Application settings).

# --- Required ---

# PostgreSQL connection string (Azure Database for PostgreSQL)
# Format: postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=

# --- Auth / Sessions ---

# Secret used to sign session cookies — use a long random string
SESSION_SECRET=

# Replit OAuth (only needed if using Replit Login integration)
# REPL_ID=
# ISSUER_URL=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Analytics ---
# Google Analytics Measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# --- Notifications ---
NOTIFICATION_EMAIL=

# --- Runtime (set automatically by Azure App Service) ---
# NODE_ENV=production
# PORT=8080   # Azure injects this; do not set manually
